# LLM API keys
OPENAI_API_KEY=

# Local LLM mode
LOCAL_LLM_API_URL=http://127.0.0.1:11434/api/chat
LOCAL_LLM_MODEL=gpt-oss

# External API mode (default in UI)
EXTERNAL_LLM_API_URL=https://api.openai.com/v1/chat/completions
EXTERNAL_LLM_MODEL=gpt-4o-mini

# Phase-2 optimization knobs
DIAGRAM_CONSENSUS_SAMPLES=3
DIAGRAM_MIN_QUALITY=2.35
