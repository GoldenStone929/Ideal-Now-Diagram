{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task_card.schema.json",
  "title": "Task Card",
  "description": "Structured record of a coding task request",
  "type": "object",
  "required": [
    "task_id",
    "task_type",
    "description",
    "requester",
    "created_at",
    "status",
    "run_id"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "task_type": {
      "type": "string",
      "enum": ["ae_summary", "lab_shift", "disposition", "listing", "qc_compare"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "requester": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["intake", "clarifying", "ready", "in_progress", "completed", "failed"]
    },
    "clarification_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "answer", "timestamp"],
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "default_applied": { "type": "boolean" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "retrieved_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "asset_id": { "type": "string" },
          "relevance_score": { "type": "number" },
          "match_type": { "type": "string", "enum": ["exact", "semantic", "keyword"] }
        }
      }
    },
    "generated_assets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Asset IDs of generated draft assets"
    },
    "comparison_results": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of compare_result records"
    },
    "review_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of review_note records"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
