{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "compare_result.schema.json",
  "title": "Compare Result",
  "description": "Result of comparing generated code/output against a reference",
  "type": "object",
  "required": [
    "compare_id",
    "task_id",
    "generated_asset_id",
    "logic_match",
    "output_match",
    "timestamp"
  ],
  "properties": {
    "compare_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "generated_asset_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "reference_asset_id": {
      "type": "string",
      "description": "Asset ID of the reference being compared against (if available)"
    },
    "logic_match": {
      "type": "boolean",
      "description": "Whether the core derivation logic matches"
    },
    "output_match": {
      "type": "boolean",
      "description": "Whether the expected output structure matches"
    },
    "similarity_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "location": { "type": "string" },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "cosmetic"]
          }
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
