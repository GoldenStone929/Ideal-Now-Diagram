{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_card.schema.json",
  "title": "Asset Card",
  "description": "Metadata record for any asset in the Clinical Coding Center",
  "type": "object",
  "required": [
    "asset_id",
    "title",
    "asset_type",
    "language",
    "status",
    "tags",
    "created_by",
    "created_at",
    "version"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$",
      "description": "UUID v4 unique identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "asset_type": {
      "type": "string",
      "enum": ["code", "logic", "template", "doc", "failed_case"]
    },
    "language": {
      "type": "string",
      "enum": ["sas", "r", "sql", "python", "markdown", "yaml", "json"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "tested", "reviewer_approved", "production_approved", "deprecated"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "task_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ae_summary", "lab_shift", "disposition", "listing", "qc_compare"]
      }
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_doc": {
      "type": "string"
    },
    "file_path": {
      "type": "string",
      "description": "Relative path to the asset file within data/"
    },
    "review_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "promotion_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from_status": { "type": "string" },
          "to_status": { "type": "string" },
          "promoted_by": { "type": "string" },
          "promoted_at": { "type": "string", "format": "date-time" },
          "reason": { "type": "string" }
        }
      }
    },
    "deprecation_reason": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
