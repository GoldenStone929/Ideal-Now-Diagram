{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "promotion_record.schema.json",
  "title": "Promotion Record",
  "description": "Record of an asset status promotion or deprecation",
  "type": "object",
  "required": [
    "promotion_id",
    "asset_id",
    "from_status",
    "to_status",
    "promoted_by",
    "promoted_at"
  ],
  "properties": {
    "promotion_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "asset_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "from_status": {
      "type": "string",
      "enum": ["draft", "tested", "reviewer_approved", "production_approved", "deprecated"]
    },
    "to_status": {
      "type": "string",
      "enum": ["draft", "tested", "reviewer_approved", "production_approved", "deprecated"]
    },
    "promoted_by": {
      "type": "string",
      "minLength": 1
    },
    "promoted_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string"
    },
    "review_note_id": {
      "type": "string",
      "description": "Associated review note ID (if promotion is due to review)"
    }
  },
  "additionalProperties": false
}
