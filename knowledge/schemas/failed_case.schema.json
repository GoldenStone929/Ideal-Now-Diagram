{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "failed_case.schema.json",
  "title": "Failed Case",
  "description": "Structured record of a failed coding task or rejected asset",
  "type": "object",
  "required": [
    "case_id",
    "related_task_id",
    "failure_type",
    "failure_description",
    "created_by",
    "created_at"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "related_task_id": {
      "type": "string",
      "pattern": "^[a-f0-9\\-]{36}$"
    },
    "related_asset_id": {
      "type": "string"
    },
    "failure_type": {
      "type": "string",
      "enum": [
        "logic_error",
        "data_mismatch",
        "missing_context",
        "wrong_template",
        "validation_failure",
        "other"
      ]
    },
    "failure_description": {
      "type": "string",
      "minLength": 1
    },
    "root_cause": {
      "type": "string"
    },
    "corrective_action": {
      "type": "string"
    },
    "related_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags or pattern IDs for indexing"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
